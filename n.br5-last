//     }

//     // 5. Извикваме рефреш на WooCommerce, за да се преизчислят таксите, ако има такива
//     $(document.body).trigger('update_checkout');
// };
//

	(function($) {
    // 1. Функция за управление на плащанията
    window.slHandlePayments = function(uid) {
        var isBoxNow = uid.toLowerCase().indexOf('boxnow') !== -1;

        // Винаги тригърваме update_checkout, за да опресним данните на сървъра
        $(document.body).trigger('update_checkout');

        // Изчакваме малко, за да може WooCommerce да презареди HTML-а на плащанията
        setTimeout(function() {
            var $codContainer = $('.payment_method_cod');
            var $codInput = $('#payment_method_cod');
            var $googlePayInput = $('#payment_method_stripe_googlepay');
            var $cardInput = $('#payment_method_stripe_cc');

            if (isBoxNow) {
                // ЛОГИКА ЗА BOXNOW: Скриваме COD и избираме Google Pay
                $codContainer.hide();

                // Трябва да използваме .trigger('click'), за да активираме Stripe скрипта
                if ($googlePayInput.length && $googlePayInput.is(':visible')) {
                    $googlePayInput.prop('checked', true).trigger('click');
                } else if ($cardInput.length) {
                    // Ако няма Google Pay, избираме карта като резервен вариант
                    $cardInput.prop('checked', true).trigger('click');
                }
            } else {
                // ЛОГИКА ЗА ДРУГИ: Показваме COD и го избираме обратно
                $codContainer.show();

                // Ако в момента е избран Google Pay (който е само за BoxNow), връщаме на Наложен платеж
                if ($googlePayInput.is(':checked') || !$('input[name="payment_method"]:checked').length) {
                    if ($codInput.length) {
                        $codInput.prop('checked', true).trigger('click');
                    }
                }
            }
        }, 600); // 600ms е по-сигурно време за мобилни устройства
    };

    // 2. Основна функция за отваряне на куриер
    window.slOpen = function(courier, mode, courierId, uid) {
        sl_CurrentCourier = courier;
        sl_CurrentMode = mode;
        sl_ActiveUID = uid;

        $('.sl-card').removeClass('active');
        $('.sl-dropdowns').hide();
        $('#box-' + uid).addClass('active');
        $('#drop-' + uid).show();
        $('#r-' + uid).prop('checked', true);

        $('#final-courier-id').val(courierId);
        $('#final-mode').val(mode);

        var fixedPriceText = $('#price-' + uid + ' .sl-price-tag').text();
        var fixedPrice = parseFloat(fixedPriceText) || 0;

        // Записваме цената в сесията чрез AJAX
        $.post('<?php echo admin_url('admin-ajax.php'); ?>', {
            action: 'sl_save_shipping_price',
            price: fixedPrice
        }, function() {
            // Веднага след успеха извикваме логиката за плащанията
            window.slHandlePayments(uid);
        });

        // Зареждане на бази данни за офиси (ако е нужно)
        if ((mode === 'office' || mode === 'locker') && !sl_MasterDB[courier]) {
            var u = {
                'speedy': 'https://couriers.lynk.bg/new/bg-speedy-offices.txt',
                'econt': 'https://couriers.lynk.bg/new/bg-econt-offices.txt',
                'boxnow': 'https://couriers.lynk.bg/new/bg-boxnow-offices.txt'
            };
            $.get(u[courier], function(res) {
                sl_MasterDB[courier] = (typeof res === 'string') ? JSON.parse(res) : res;
            });
        }

        slGlobalSync();
    };

})(jQuery);

// Модифицирайте вашата съществуваща slOpen функция, за да извиква логиката за плащания
var originalSlOpen = window.slOpen;
window.slOpen = function(courier, mode, courierId, uid) {
    // Извикваме оригиналната логика
    originalSlOpen(courier, mode, courierId, uid);

    // Добавяме новата логика за плащания
    slHandlePayments(uid);
};
    </script>
    <?php
}

