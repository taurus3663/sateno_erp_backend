
/**
 * SILIYAN ERP - SHIPPING MODULE (MODE-SPECIFIC PRICES ONLY)
 */
// 1. ВАЛИДАЦИЯ ПРИ ПОРЪЧКА - ПРОВЕРКА ЗА ИЗБРАНИ ДЕТАЙЛИ
add_action( 'woocommerce_checkout_process', function() {
    if ( empty($_POST['siliyan_courier_full']) ) {
        wc_add_notice( 'Моля, изберете метод на доставка.', 'error' );
        return;
    }

    $unique_id = $_POST['siliyan_courier_full']; // Пример: speedy_office_10
    $parts = explode('_', $unique_id);
    $mode = $parts[1] ?? ''; // office, locker или address

    if ($mode === 'office' || $mode === 'locker') {
        // Проверка дали е избран офис от падащото меню (скритото поле sl_val_...)
        if ( empty($_POST['sl_val_' . $unique_id]) ) {
            wc_add_notice( 'Моля, изберете конкретен офис или автомат от списъка.', 'error' );
        }
    } elseif ($mode === 'address') {
    // 1. Проверка за ГРАД
    // Взимаме "Бургас" и махаме интервалите
    $city = isset($_POST['billing_city']) ? trim($_POST['billing_city']) : '';

    if ( empty($city) || mb_strlen($city) < 2 ) {
        wc_add_notice( '<strong>Грешка:</strong> Моля, изберете град за доставка.', 'error' );
    }

    // 2. Проверка за УЛИЦА
    // Взимаме "[ADDRESS] [] [ECONT]"
    $address = isset($_POST['billing_address_1']) ? trim($_POST['billing_address_1']) : '';
    // Тук е хитрината: Махаме всичко излишно, за да видим дали потребителят е писал нещо
    $clean_street = str_replace(['[ADDRESS]', '[]', '[ECONT]', '[SPEEDY]', '[BOXNOW]'], '', $address);
    $clean_street = trim($clean_street); // Остава само това, което е между таговетеф

// 		echo "<script>console.log('ERP Debug - Clean Street: " . esc_js($clean_street) . "');</script>";
    // Ако потребителят не е въвел нищо, $clean_street ще е празен низ ""
    if ( empty($clean_street) || mb_strlen($clean_street) < 3 ) {
        wc_add_notice( '<strong>Грешка:</strong> Моля, въведете точен адрес (улица и номер).', 'error' );
    }
}
});

// 2. СКРИВАНЕ НА СТАНДАРТНИТЕ ПОЛЕТА
add_filter( 'woocommerce_checkout_fields', function( $fields ) {
    $allowed = ['billing_first_name', 'billing_last_name', 'billing_phone', 'billing_email'];
    foreach ( $fields['billing'] as $key => $field ) {
        if ( ! in_array( $key, $allowed ) ) {
            $fields['billing'][$key]['type'] = 'hidden';
            $fields['billing'][$key]['label'] = '';
            $fields['billing'][$key]['required'] = false;
        }
    }
    return $fields;
});

// 1. Изключваме проверката на формата на пощенския код (валидацията)
add_filter( 'woocommerce_validate_postcode', '__return_true', 100 );

// 2. Допълнителна застраховка: премахваме изискването на ниво държава
add_filter( 'woocommerce_get_country_locale', function( $locale ) {
    foreach ( $locale as $country => $fields ) {
        if ( isset( $locale[$country]['postcode'] ) ) {
            $locale[$country]['postcode']['required'] = false;
            $locale[$country]['postcode']['validate'] = false; // Изключва валидацията
        }
    }
    return $locale;
}, 100 );




// 3. ДОБАВЯНЕ НА СКРИТИ ПОЛЕТА ЗА ERP-ТО
add_filter( 'woocommerce_billing_fields' , 'siliyan_add_custom_billing_fields' );
function siliyan_add_custom_billing_fields( $fields ) {
    $fields['billing_office_code'] = array('type' => 'hidden', 'required' => false, 'class' => array('sl-hidden'));
    $fields['billing_courier_type'] = array('type' => 'hidden', 'required' => false, 'class' => array('sl-hidden'));
    return $fields;
}

// 4. ОСНОВЕН МОДУЛ ЗА ДОСТАВКА
add_action( 'woocommerce_after_checkout_billing_form', 'siliyan_erp_advanced_search' );

function siliyan_erp_advanced_search() {

	if ( WC()->session ) {
        WC()->session->set('sl_shipping_price', null);
    }

    $cart = WC()->cart;
    $cart_items = array();
    $total_weight = 0;

    foreach ( $cart->get_cart() as $cart_item_key => $cart_item ) {
        $_product = $cart_item['data'];
        $quantity = $cart_item['quantity'];
        $total_weight += (float)$_product->get_weight() * $quantity;
        $cart_items[] = array(
            'id'       => $cart_item['product_id'],
            'name'     => $_product->get_name(),
            'sku'      => $_product->get_sku(),
            'quantity' => $quantity,
            'price'    => $cart_item['line_total'],
            'weight'   => (float)$_product->get_weight(),
        );
    }

    $api_url = 'https://erp.sateno.bg/erp/checkout/check-couriers';
    $response = wp_remote_post( $api_url, array(
        'body'    => json_encode(array(
            'site'        => "sateno.bg",
            'cart_total'  => $cart->get_total('edit'),
            'cart_weight' => $total_weight,
            'items_count' => $cart->get_cart_contents_count(),
            'items'       => $cart_items,
            'currency'    => get_woocommerce_currency()
        )),
        'headers' => array( 'Content-Type' => 'application/json' ),
        'timeout' => 15
    ));

    if ( is_wp_error( $response ) ) return;

    $data = json_decode( wp_remote_retrieve_body( $response ), true );
    $delivery_options = $data['checkOutCourierList'] ?? [];
    $currency_symbol = $data['currencySymbol'] ?? '€';
    $cities_json = wp_remote_retrieve_body(wp_remote_get("https://couriers.lynk.bg/new/bg-cities.txt"));

    ?>

    <script>
        // Функция за автоматично превръщане на латиница в кирилица
        function slToCyrillic(text) {
            if (!text) return "";
            var lat = "abvgdeziyklmnoprstufhc\"\'yxwABVGDEZIYKLMNOPRSTUFHC\"\'YXW".split("");
            var cyr = "абвгдезийклмнопрстуфхцшщъьюяАБВГДЕЗИЙКЛМНОПРСТУФХЦШЩЪЬЮЯ".split("");
            var map = { 'sh': 'ш', 'ch': 'ц', 'zh': 'ж', 'sht': 'щ', 'yu': 'ю', 'ya': 'я', 'SH': 'Ш', 'CH': 'Ц', 'ZH': 'Ж', 'SHT': 'Щ', 'YU': 'Ю', 'YA': 'Я' };
            var out = text;
            for (var key in map) { out = out.replace(new RegExp(key, 'g'), map[key]); }
            for (var i = 0; i < lat.length; i++) { out = out.replace(new RegExp(lat[i], 'g'), cyr[i]); }
            return out;
        }

        var sl_CitiesList = <?php echo $cities_json ?: '{}'; ?>;
        var sl_MasterDB = { speedy: null, econt: null, boxnow: null };
        var sl_CurrentCourier = '';
        var sl_CurrentMode = '';
        var sl_ActiveUID = '';
        var sl_CartWeight = <?php echo $total_weight; ?>;
        var sl_CartTotal = "<?php echo $cart->get_total('edit'); ?>";
        var sl_CurrencySymbol = "<?php echo $currency_symbol; ?>";
    </script>

    <div id="sl-shipping-system" style="clear:both; margin-top:30px;">
        <h3 style="font-weight:600; margin-bottom:15px; font-size:18px;">Метод на доставка</h3>

        <div class="sl-shipping-wrapper" style="display: flex; flex-direction: column; gap: 0px;background:unset;border-radius: unset !important;">
        <?php
        if (!empty($delivery_options)) :
            foreach ($delivery_options as $opt):
                $slug = str_replace('_', '', strtolower($opt['courierType']));
                $courier_id = $opt['id'] ?? 0;

                $modes_config = [
                    'office'  => ['label' => 'До офис', 'price' => (float)($opt['officeFixedShippingPrice'] ?? 0)],
                    'locker'  => ['label' => 'До автомат', 'price' => (float)($opt['lockerFixedShippingPrice'] ?? 0)],
                    'address' => ['label' => 'До адрес', 'price' => (float)($opt['addressFixedShippingPrice'] ?? 0)]
                ];

                foreach ($modes_config as $m_key => $m_data):
                    if (empty($opt[$m_key])) continue;
                    $unique_id = $slug . '_' . $m_key . '_' . $courier_id;
                    $current_price = $m_data['price'];
        ?>
            <div class="sl-card" id="box-<?php echo $unique_id; ?>" onclick="slOpen('<?php echo $slug; ?>', '<?php echo $m_key; ?>', <?php echo $courier_id; ?>, '<?php echo $unique_id; ?>')">
                <div class="sl-row">
                    <div class="sl-info" style="display: flex;">
                        <input type="radio" name="siliyan_courier_full" value="<?php echo $unique_id; ?>" id="r-<?php echo $unique_id; ?>">
                        <label for="r-<?php echo $unique_id; ?>" style="cursor:pointer; margin:unset;">
                            <strong><?php echo $m_data['label']; ?></strong>
                            <span class="price-holder" id="price-<?php echo $unique_id; ?>">
                                <?php echo ($current_price <= 0) ? '<span class="sl-badge-free">БЕЗПЛАТНA</span>' : '<span class="sl-price-tag">'.number_format($current_price, 2).' '.$currency_symbol.'</span>'; ?>
                            </span>
                        </label>
                    </div>
                    <img class="sl-courier-logo" style="max-width: 85px !important;" src="https://co.middleware.bg/courier-menus/<?php echo $slug; ?>-logo.png" width="90" onerror="this.style.visibility='hidden'">
                </div>

                <div class="sl-dropdowns" id="drop-<?php echo $unique_id; ?>" style="display:none; margin-top:15px;">
                    <div class="sl-selection-group">
                        <div class="sl-label-mini" style="font-size: 11px; color: #888; margin-bottom: 2px;">ИЗБРАНО:</div>
                       <div class="sl-main-input-wrapper" style="position: relative; width: 100%;margin: 0 auto;">
    <div
        id="display-<?php echo $unique_id; ?>"
        class="sl-main-field-div"
        onclick="slToggleHelper('<?php echo $unique_id; ?>')"
    >
        <span class="sl-placeholder">Изберете от списъка...</span>
    </div>
    <span class="sl-dropdown-arrow" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #888;">▼</span>
</div>

                        <div id="helper-box-<?php echo $unique_id; ?>" class="sl-helper-box" style="display:none; margin-top: 5px;">
                            <input type="text" id="input-<?php echo $unique_id; ?>" class="sl-helper-input <?php echo ($m_key === 'address' ? 'city-autocomplete' : 'combined-search'); ?>" placeholder="Пишете тук..." autocomplete="off">
                            <div id="<?php echo ($m_key === 'address' ? 'city-results-' : 'results-'); ?><?php echo $unique_id; ?>" class="mw-results-list"></div>
                        </div>

                        <?php if ($m_key === 'address'): ?>
                            <div class="flex-street-number" style="display: flex; gap: 5px; margin-top: 10px;">
                                <div style="flex: 1;">
                                    <div style="font-size: 11px; color: #888;">УЛИЦА И НОМЕР:</div>
                                    <input type="text" id="street-<?php echo $unique_id; ?>" class="sl-search-input street-field" oninput="slGlobalSync()">
                                </div>
                                <div style="width: 80px;">
                                    <div style="font-size: 11px; color: #888;">ПК:</div>
                                    <input type="text" id="postcode-<?php echo $unique_id; ?>" class="sl-search-input pc-field" readonly>
                                </div>
                            </div>
                            <input type="hidden" id="city-hidden-<?php echo $unique_id; ?>" class="city-hidden">
                        <?php endif; ?>
                        <input type="hidden" name="sl_val_<?php echo $unique_id; ?>" id="val-<?php echo $unique_id; ?>">
                    </div>
                </div>
            </div>
        <?php endforeach; endforeach; endif; ?>
        </div>
        <input type="hidden" name="siliyan_courier_id" id="final-courier-id">
