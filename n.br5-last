    <script>
    (function($) {
       window.slOpen = function(courier, mode, courierId, uid) {
    sl_CurrentCourier = courier;
    sl_CurrentMode = mode;
    sl_ActiveUID = uid;

    $('.sl-card').removeClass('active');
    $('.sl-dropdowns').hide();
    $('#box-' + uid).addClass('active');
    $('#drop-' + uid).show();
    $('#r-' + uid).prop('checked', true);

    $('#final-courier-id').val(courierId);
    $('#final-mode').val(mode);

    // Взимаме фиксираната цена, която вече съществува в HTML баджа
    var fixedPriceText = $('#price-' + uid + ' .sl-price-tag').text();
    var fixedPrice = parseFloat(fixedPriceText) || 0;

    // СИНХРОНИЗАЦИЯ: Веднага записваме тази цена в сесията
    $.post('<?php echo admin_url('admin-ajax.php'); ?>', {
        action: 'sl_save_shipping_price',
        price: fixedPrice
    }, function() {sl_save_shipping_to_order
        // Обновяваме тоталите вдясно веднага
        $(document.body).trigger('update_checkout');
    });

		   $(document.body).trigger('update_checkout');

    if ((mode === 'office' || mode === 'locker') && !sl_MasterDB[courier]) {
        var u = {
            'speedy': 'https://couriers.lynk.bg/new/bg-speedy-offices.txt',
            'econt': 'https://couriers.lynk.bg/new/bg-econt-offices.txt',
            'boxnow': 'https://couriers.lynk.bg/new/bg-boxnow-offices.txt'
        };
        $.get(u[courier], function(res) {
            sl_MasterDB[courier] = (typeof res === 'string') ? JSON.parse(res) : res;
        });
    }

    slGlobalSync();
};

       window.slToggleHelper = function(uid) {
    $('.sl-helper-box').hide();
    $('#helper-box-' + uid).slideDown(100);

    var inputField = $('#input-' + uid);

    // 1. Задаваме "София" като начална стойност
//     inputField.val('София').focus();

    // 2. Маркираме текста, за да може потребителят да започне да пише върху него веднага
    inputField.select();

    // 3. Изкуствено задействаме събитието за писане, за да се запълни списъка
    inputField.trigger('input');
};

       window.slGlobalSync = function() {
    if (!sl_ActiveUID) return;

    var uid = sl_ActiveUID;
    var city = "";
    var pc = "";
    var addr = "";

    if (sl_CurrentMode !== 'address') {
        // --- ЛОГИКА ЗА ОФИС/АВТОМАТ ---
        var code = $('#val-' + uid).val() || "";

        // ВАЖНО: Използваме .text(), защото display е DIV, а не input
        var displayVal = $('#display-' + uid).text() || "";

        // Пречистваме плейсхолдъра, ако още нищо не е избрано
        if (displayVal.indexOf('Изберете') !== -1) displayVal = "";

        if (displayVal && code) {
            addr = "[" + sl_CurrentMode.toUpperCase() + "] " + displayVal + " [" + code + "] [" + sl_CurrentCourier.toUpperCase() + "]";
            city = displayVal.split(' - ')[0] || "";
        }
    } else {
        // --- ЛОГИКА ЗА АДРЕС ---
        // Увери се, че ID-то на полето е точно 'street-' + uid
        var street = $('#street-' + uid).val() || "";
        city = $('#city-hidden-' + uid).val() || "";
        pc = $('#postcode-' + uid).val() || "";

        if (city && street) {
            addr = "[ADDRESS] " + street + " [] [" + sl_CurrentCourier.toUpperCase() + "]";
        }
    }

    // Пълним полетата на WooCommerce
    // Използваме .trigger('change'), за да разбере WooCommerce, че има нова стойност
    if (city) $('#billing_city, #shipping_city').val(city.trim()).trigger('change');
    if (pc) $('#billing_postcode, #shipping_postcode').val(pc.trim()).trigger('change');
    if (addr) $('#billing_address_1, #shipping_address_1').val(addr.trim()).trigger('change');

    // Дебъг конзола - отвори F12, за да видиш дали се пълнят
    // console.log("ERP Sync -> City: " + city + " | Addr: " + addr);
};

      window.slSelectOffice = function(uid, label, code, pc, city) {
    // Слагаме текста директно в дива (това премахва и плейсхолдъра)
    $('#display-' + uid).html(label);

    // Записваме кода в скритото поле за поръчката
    $('#val-' + uid).val(code);

    $('.sl-helper-box').hide();
    slGlobalSync();
    slRecalculate(code, pc, city);
};

        window.slSelectCity = function(uid, city, pc) {
    // Слагаме града в дива
    $('#display-' + uid).html(city);

    $('#city-hidden-' + uid).val(city);
    $('#postcode-' + uid).val(pc);

    $('.sl-helper-box').hide();
    $('#street-' + uid).focus();
    slGlobalSync();
    slRecalculate('', pc, city);
};

		// Автоматично избиране на първия куриер след 1 секунда
setTimeout(function() {
    var firstCard = $('.sl-card').first();
    if (firstCard.length > 0) {
        // Извличаме параметрите от onclick атрибута на първата карта
        // Очакваме формат: slOpen('slug', 'mode', id, 'uid')
        firstCard.click();
        console.log('ERP: Автоматично избран първи метод на доставка.');
    }
}, 500);

        $(document).on('input', '.combined-search', function() {
            var uid = this.id.replace('input-', ''), courier = uid.split('_')[0];
            var term = slToCyrillic($(this).val()).toLowerCase(), html = '', count = 0;
            if (!sl_MasterDB[courier]) return;
            $.each(sl_MasterDB[courier], function(key, value) {
                $.each(Array.isArray(value) ? value : [value], function(i, off) {
                    var label = (off.city || key).toUpperCase() + " - " + off.name;
                    if (label.toLowerCase().includes(term)) {
                        html += `<div class="mw-item" onclick="slSelectOffice('${uid}','${label}','${off.code}','${off.postCode || ''}','${off.city || key}')">🏢 ${label}</div>`;
                        count++;
                    }
                    if (count >= 20) return false;
                });
                if (count >= 20) return false;
            });
            $('#results-' + uid).html(html).show();

			if(window.innerWidth <= 768) {
					var $this = $(this);
			var targetScroll = $this.offset().top - 80;
			 $("html, body").animate({ scrollTop: targetScroll }, "slow");
			}
        });

        $(document).on('input', '.city-autocomplete', function() {
            var uid = this.id.replace('input-', ''), term = slToCyrillic($(this).val()).toLowerCase(), html = '', count = 0;
            $.each(sl_CitiesList, function(city, zips) {
                if (city.toLowerCase().includes(term)) {
                    $.each(zips, function(pc, data) {
                        html += `<div class="mw-item" onclick="slSelectCity('${uid}','${city}','${pc}')">📍 ${city} (${pc})</div>`;
                        count++;
                    });
                }
                if (count >= 10) return false;
            });
            $('#city-results-' + uid).html(html).show();
				if(window.innerWidth <= 768) {
					var $this = $(this);
			var targetScroll = $this.offset().top - 80;
			 $("html, body").animate({ scrollTop: targetScroll }, "slow");
			}
        });

        $(document).on('click', function(e) {
            if (!$(e.target).closest('.sl-selection-group').length) $('.sl-helper-box').hide();
        });

       window.slRecalculate = function(targetId, pc, city) {
    var uid = sl_ActiveUID;
    $('#price-' + uid).html('...');

    $.ajax({
        url: 'https://erp.sateno.bg/erp/checkout/recalculate-price2',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({
            site: window.location.hostname,
            cart_total: sl_CartTotal,
            cart_weight: sl_CartWeight,
            courierType: sl_CurrentCourier.toUpperCase(),
            courierShipmentType: sl_CurrentMode.toUpperCase(),
            targetId: String(targetId),
            postcode: String(pc),
            cityName: String(city),
            items: <?php echo json_encode($cart_items); ?>
        }),
        success: function(res) {
            if (res !== undefined) {
                var p = parseFloat(res);

                // 1. Обновяваме визуално цената в левия панел
                $('#price-' + uid).html(p <= 0 ? '<span class="sl-badge-free">БЕЗПЛАТНA</span>' : '<span class="sl-price-tag">' + p.toFixed(2) + ' ' + sl_CurrencySymbol + '</span>');

                // 2. КЛЮЧОВО: Пращаме цената към WordPress сесията
                $.ajax({
                    url: '<?php echo admin_url('admin-ajax.php'); ?>',
                    type: 'POST',
                    data: {
                        action: 'sl_save_shipping_price',
                        price: p
                    },
                    success: function() {
                        // 3. Едва сега казваме на WooCommerce да обнови тоталите вдясно
                        $(document.body).trigger('update_checkout');
                    }
                });
            }
        }
    });
};
    })(jQuery);


