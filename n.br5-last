add_action('wp_ajax_sl_recalculate_proxy', 'sl_recalculate_proxy_func');
add_action('wp_ajax_nopriv_sl_recalculate_proxy', 'sl_recalculate_proxy_func');
function sl_recalculate_proxy_func() {
    $response = wp_remote_post('https://erp.sateno.bg/erp/checkout/recalculate-price2', array(
        'body' => file_get_contents('php://input'),
        'headers' => array('Content-Type' => 'application/json'),
        'timeout' => 15
    ));
    echo is_wp_error($response) ? '0' : wp_remote_retrieve_body($response);
    wp_die();
}

