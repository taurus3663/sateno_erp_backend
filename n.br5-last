/**
 * Build payload similar to WooCommerce wc/v3/orders webhook.
 *
 * @param int $order_id
 * @return array|null
 */
add_action('woocommerce_thankyou', 'mw_send_webhook_after_thankyou', 10, 1);

function mw_send_webhook_after_thankyou($order_id) {
    $payload = mw_build_order_webhook_payload($order_id);

    if (!$payload) {
        return;
    }
    $webhooks = getWebHookData();
    $webhook_url = $webhooks->delivery_url; // change this
    $secret = $webhooks->secret; // MUST MATCH receiver
    // IMPORTANT: Woo signature = base64(hmac_sha256(payload, secret))
    $signature = base64_encode(hash_hmac('sha256', wp_json_encode($payload), $secret, true));

    $headers = array(
        'Content-Type' => 'application/json',
        'User-Agent' => 'WooCommerce/' . WC()->version . '; ' . home_url(),
        // Required Woo headers:
        'X-WC-Webhook-Source' => home_url(),
        'X-WC-Webhook-Topic' => 'order.created', // must match receiver logic
        'X-WC-Webhook-Resource' => 'order',
        'X-WC-Webhook-Event' => 'created',
        'X-WC-Webhook-Signature' => $signature,
        'X-WC-Webhook-ID' => '999999', // any numeric ID, normally Woo uses an internal webhook ID
    );

    $response = wp_remote_post($webhook_url, array(
        'method' => 'POST',
        'timeout' => 0.01,
        'blocking' => false,
        'headers' => $headers,
        'body' => wp_json_encode($payload),
    ));

    if (is_wp_error($response)) {
        error_log('[MW] Webhook send error for order ' . $order_id . ': ' . $response->get_error_message());
    }
};

function mw_build_order_webhook_payload($order_id) {
    $order = wc_get_order($order_id);

    if (!$order) {
        return null;
    }
    // Basic fields
    $payload = array(
        'id' => $order->get_id(),
        'parent_id' => $order->get_parent_id(),
        'status' => $order->get_status(), // e.g. 'abandoned', 'processing'
        'currency' => $order->get_currency(),
        'version' => WC()->version,
        'prices_include_tax' => wc_prices_include_tax(),
        'date_created' => $order->get_date_created() ? $order->get_date_created()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'date_modified' => $order->get_date_modified() ? $order->get_date_modified()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'discount_total' => $order->get_discount_total(),
        'discount_tax' => $order->get_discount_tax(),
        'shipping_total' => $order->get_shipping_total(),
        'shipping_tax' => $order->get_shipping_tax(),
        'cart_tax' => $order->get_cart_tax(),
        'total' => $order->get_total(),
        'total_tax' => $order->get_total_tax(),
        'customer_id' => $order->get_customer_id(),
        'order_key' => $order->get_order_key(),
        'billing' => array(
            'first_name' => $order->get_billing_first_name(),
            'last_name' => $order->get_billing_last_name(),
            'company' => $order->get_billing_company(),
            'address_1' => $order->get_billing_address_1(),
            'address_2' => $order->get_billing_address_2(),
            'city' => $order->get_billing_city(),
            'state' => $order->get_billing_state(),
            'postcode' => $order->get_billing_postcode(),
            'country' => $order->get_billing_country(),
            'email' => $order->get_billing_email(),
            'phone' => $order->get_billing_phone(),
        ),
        'shipping' => array(
            'first_name' => $order->get_shipping_first_name(),
            'last_name' => $order->get_shipping_last_name(),
            'company' => $order->get_shipping_company(),
            'address_1' => $order->get_shipping_address_1(),
            'address_2' => $order->get_shipping_address_2(),
            'city' => $order->get_shipping_city(),
            'state' => $order->get_shipping_state(),
            'postcode' => $order->get_shipping_postcode(),
            'country' => $order->get_shipping_country(),
            'phone' => $order->get_shipping_phone(),
        ),
        'payment_method' => $order->get_payment_method(),
        'payment_method_title' => $order->get_payment_method_title(),
        'transaction_id' => $order->get_transaction_id(),
        'customer_ip_address' => $order->get_customer_ip_address(),
        'customer_user_agent' => $order->get_customer_user_agent(),
        'created_via' => $order->get_created_via(),
        'customer_note' => $order->get_customer_note(),
        'date_completed' => $order->get_date_completed() ? $order->get_date_completed()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'date_paid' => $order->get_date_paid() ? $order->get_date_paid()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'cart_hash' => $order->get_cart_hash(),
        'number' => $order->get_order_number(),
        'meta_data' => array(),
        'line_items' => array(),
        'tax_lines' => array(),
        'shipping_lines' => array(),
        'fee_lines' => array(),
        'coupon_lines' => array(),
        'refunds' => array(),
        'payment_url' => $order->get_checkout_payment_url(),
        'is_editable' => $order->is_editable(),
        'needs_payment' => $order->needs_payment(),
        'needs_processing' => $order->needs_processing(),
        'date_created_gmt' => $order->get_date_created() ? $order->get_date_created()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'date_modified_gmt' => $order->get_date_modified() ? $order->get_date_modified()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'date_completed_gmt' => $order->get_date_completed() ? $order->get_date_completed()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'date_paid_gmt' => $order->get_date_paid() ? $order->get_date_paid()->date_i18n('Y-m-d\TH:i:s', true) : null,
        'currency_symbol' => html_entity_decode(get_woocommerce_currency_symbol($order->get_currency())),
        '_links' => array(
            'self' => array(
                array(
                    'href' => rest_url(sprintf('wc/v3/orders/%d', $order->get_id())),
                    'targetHints' => array(
                        'allow' => array('GET', 'POST', 'PUT', 'PATCH', 'DELETE'),
                    ),
                ),
            ),
            'collection' => array(
                array(
                    'href' => rest_url('wc/v3/orders'),
                ),
            ),
            'customer' => $order->get_customer_id() ? array(
                array(
                    'href' => rest_url(sprintf('wc/v3/customers/%d', $order->get_customer_id())),
                ),
            ) : array(),
        ),
        'new_version' => 1
    );

    // Order meta_data
    foreach ($order->get_meta_data() as $meta) {
        $payload['meta_data'][] = array(
            'id' => $meta->id,
            'key' => $meta->key,
            'value' => $meta->value,
        );
    }

    // Line items
    foreach ($order->get_items('line_item') as $item_id => $item) {
        $product = $item->get_product();
        $image_id = $product ? $product->get_image_id() : 0;
        $image_src = $image_id ? wp_get_attachment_image_url($image_id, 'full') : '';

        $item_data = array(
            'id' => $item_id,
            'name' => $item->get_name(),
            'product_id' => $item->get_product_id(),
            'variation_id' => $item->get_variation_id(),
            'quantity' => $item->get_quantity(),
            'tax_class' => $item->get_tax_class(),
            'subtotal' => $item->get_subtotal(),
            'subtotal_tax' => $item->get_subtotal_tax(),
            'total' => $item->get_total(),
            'total_tax' => $item->get_total_tax(),
            'taxes' => $item->get_taxes(),
            'meta_data' => array(),
            'sku' => $product ? $product->get_sku() : '',
            'price' => $item->get_total() / max(1, $item->get_quantity()),
            'image' => array(
                'id' => $image_id,
                'src' => $image_src,
            ),
            'parent_name' => $product && $product->get_parent_id() ? get_the_title($product->get_parent_id()) : '',
        );

        foreach ($item->get_meta_data() as $meta) {
            $item_data['meta_data'][] = array(
                'id' => $meta->id,
                'key' => $meta->key,
                'value' => $meta->value,
                'display_key' => wc_attribute_label($meta->key),
                'display_value' => wc_clean($meta->value),
            );
        }


        $payload['line_items'][] = $item_data;
    }

    // Shipping lines
    foreach ($order->get_shipping_methods() as $item_id => $item) {
        $payload['shipping_lines'][] = array(
            'id' => $item_id,
            'method_title' => $item->get_name(),
            'method_id' => $item->get_method_id(),
            'instance_id' => $item->get_instance_id(),
            'total' => $item->get_total(),
            'total_tax' => $item->get_total_tax(),
            'taxes' => $item->get_taxes(),
            'tax_status' => $item->get_tax_status(),
            'meta_data' => array_map(function ($meta) {
                return array(
                    'id' => $meta->id,
                    'key' => $meta->key,
                    'value' => $meta->value,
                );
            }, $item->get_meta_data()),
        );
    }

    // Tax lines
    foreach ($order->get_items('tax') as $item_id => $item) {
        $payload['tax_lines'][] = array(
            'id' => $item_id,
            'rate_code' => $item->get_rate_code(),
            'rate_id' => $item->get_rate_id(),
            'label' => $item->get_label(),
            'compound' => (bool) $item->get_compound(),
            'tax_total' => $item->get_tax_total(),
            'shipping_tax_total' => $item->get_shipping_tax_total(),
            'meta_data' => array(),
        );
    }

    // Fee lines
    foreach ($order->get_items('fee') as $item_id => $item) {
        $payload['fee_lines'][] = array(
            'id' => $item_id,
            'name' => $item->get_name(),
            'tax_class' => $item->get_tax_class(),
            'tax_status' => $item->get_tax_status(),
            'total' => $item->get_total(),
            'total_tax' => $item->get_total_tax(),
            'taxes' => $item->get_taxes(),
            'meta_data' => array(),
        );
    }

    // Coupon lines
    foreach ($order->get_items('coupon') as $item_id => $item) {
        $payload['coupon_lines'][] = array(
            'id' => $item_id,
            'code' => $item->get_code(),
            'discount' => $item->get_discount(),
            'discount_tax' => $item->get_discount_tax(),
            'meta_data' => array(),
        );
    }

    // Refunds
    foreach ($order->get_refunds() as $refund) {
        $payload['refunds'][] = array(
            'id' => $refund->get_id(),
            'reason' => $refund->get_reason(),
            'total' => $refund->get_amount(),
            'date_created' => $refund->get_date_created() ? $refund->get_date_created()->date_i18n('Y-m-d\TH:i:s', true) : null,
        );
    }

    return $payload;
}

function getWebHookData() {
    global $wpdb;
    // Вече търсим запис, който съдържа твоя домейн erp.sateno.bg
    $result = $wpdb->get_results("SELECT delivery_url, secret FROM {$wpdb->prefix}wc_webhooks WHERE delivery_url LIKE '%erp.sateno.bg%' AND status = 'active' LIMIT 1");

    if (empty($result)) {
        return null;
    }

    return $result[0];
}

add_filter( 'woocommerce_rest_is_request_to_rest_api', function( $is_rest_api_request ) {
    if ( ! $is_rest_api_request && strpos( $_SERVER['REQUEST_URI'], '/wp-json/wp/v2/media' ) !== false ) {
        return true;
    }
    return $is_rest_api_request;
});


// 1. Запазваме цената на доставката в сесията при recalculate
add_action('wp_ajax_nopriv_sl_save_shipping_price', 'sl_save_shipping_price');
add_action('wp_ajax_sl_save_shipping_price', 'sl_save_shipping_price');
function sl_save_shipping_price() {
    $price = floatval($_POST['price'] ?? 0);
    WC()->session->set('sl_shipping_price', $price);
    wp_send_json_success();
}

// 2. Добавяме реда "Доставка" в order review таблицата
add_action('woocommerce_review_order_before_order_total', 'sl_show_shipping_row', 10);
function sl_show_shipping_row() {
    $session_value = WC()->session->get('sl_shipping_price');

    // Ако потребителят още не е избрал нищо, сесията ще е null или няма да съществува
    if ( is_null($session_value) ) {
        return; // Спираме до тук и не показваме реда "Доставка"
    }

    $price = floatval($session_value);
    ?>
    <tr class="sl-shipping-row">
        <th style="font-weight:600;">Доставка</th>
        <td style="text-align:right;">
            <?php if ($price <= 0): ?>
                <span style="color: var(--wd-primary-color);padding:2px 8px;border-radius:4px;font-weight:bold;font-size:12px;">БЕЗПЛАТНA</span>
            <?php else: ?>
                <span style="color: var(--wd-primary-color);font-weight: 600;">
                    <?php echo number_format($price, 2); ?> <?php echo html_entity_decode(get_woocommerce_currency_symbol()); ?>
                </span>
            <?php endif; ?>
        </td>
    </tr>
    <?php
}

// 3. Добавяме цената на доставката към общото
add_filter('woocommerce_calculated_total', 'sl_add_shipping_to_total', 10, 2);
function sl_add_shipping_to_total($total, $cart) {
    $price = WC()->session->get('sl_shipping_price');

    // Добавяме сумата само ако не е null
    if ( ! is_null($price) ) {
        return $total + floatval($price);
    }

    return $total;
}

// 4. Записваме цената в order meta при поръчка
add_action('woocommerce_checkout_create_order', 'sl_save_shipping_to_order_final', 20, 2);
function sl_save_shipping_to_order_final($order, $data) {
    $price = floatval(WC()->session->get('sl_shipping_price', 0));
    if ($price > 0) {
        $item = new WC_Order_Item_Shipping();

        $currency_symbol = html_entity_decode(get_woocommerce_currency_symbol());
        $formatted_price = number_format($price, 2) . ' ' . $currency_symbol;

        // Използваме span с клас, за да го оцветим чрез CSS
        $display_title = ' <span class="sl-final-price">' . $formatted_price . '</span>';

        $item->set_method_title($display_title);
        $item->set_method_id('siliyan_erp_shipping');
        $item->set_total($price);
        $order->add_item($item);
    }
}

/**
 * 1. СИНХРОНИЗАЦИЯ: Прихващаме избора на куриер по време на AJAX обновяването на Checkout-а.
 * Това гарантира, че $_POST['siliyan_courier_full'] ще съществува, когато Woo проверява плащанията.
 */
add_action( 'woocommerce_checkout_update_order_review', function( $post_data ) {
    parse_str( $post_data, $params );
    if ( isset( $params['siliyan_courier_full'] ) ) {
        $_POST['siliyan_courier_full'] = $params['siliyan_courier_full'];
    }
});

/**
 * 2. ДИНАМИЧНИ ПЛАЩАНИЯ: Премахваме COD само ако е BoxNow.
 * Тъй като използваме горния action, $_POST вече е запълнен правилно.
 */
add_filter( 'woocommerce_available_payment_gateways', 'sl_dynamic_payment_gateways', 999 );
function sl_dynamic_payment_gateways( $gateways ) {
    if ( is_admin() ) return $gateways;

    // Взимаме избрания куриер от инжектирания POST или директния POST
    $chosen_courier = $_POST['siliyan_courier_full'] ?? '';

    // Ако няма данни в $_POST, проверяваме и в $_REQUEST за всеки случай
    if ( empty( $chosen_courier ) && isset( $_REQUEST['post_data'] ) ) {
        parse_str( $_REQUEST['post_data'], $post_data );
        $chosen_courier = $post_data['siliyan_courier_full'] ?? '';
    }

    // ЛОГИКА: Ако съдържа 'boxnow', махаме COD. Ако НЕ съдържа, COD остава наличен.
    if ( ! empty( $chosen_courier ) && strpos( strtolower( $chosen_courier ), 'boxnow' ) !== false ) {
        unset( $gateways['cod'] );
    }

    return $gateways;
}