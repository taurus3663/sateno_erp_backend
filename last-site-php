function siliyan_erp_advanced_search() {
    $cart = WC()->cart;
    $cart_items = array();
    $total_weight = 0;

    foreach ( $cart->get_cart() as $cart_item_key => $cart_item ) {
        $_product = $cart_item['data'];
        $quantity = $cart_item['quantity'];
        $total_weight += (float)$_product->get_weight() * $quantity;
        $cart_items[] = array(
            'id'       => $cart_item['product_id'],
            'name'     => $_product->get_name(),
            'sku'      => $_product->get_sku(),
            'quantity' => $quantity,
            'price'    => $cart_item['line_total'],
            'weight'   => (float)$_product->get_weight(),
        );
    }

    $api_url = 'https://erp.sateno.bg/erp/checkout/check-couriers';
    $response = wp_remote_post( $api_url, array(
        'body'    => json_encode(array(
            'site'        => $_SERVER['HTTP_HOST'],
            'cart_total'  => $cart->get_total('edit'),
            'cart_weight' => $total_weight,
            'items_count' => $cart->get_cart_contents_count(),
            'items'       => $cart_items,
            'currency'    => get_woocommerce_currency()
        )),
        'headers' => array( 'Content-Type' => 'application/json' ),
        'timeout' => 15
    ));

    if ( is_wp_error( $response ) ) return;

    $data = json_decode( wp_remote_retrieve_body( $response ), true );
    $delivery_options = $data['checkOutCourierList'] ?? [];
    $currency_symbol = $data['currencySymbol'] ?? '€';
