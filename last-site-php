            if (words.every(w => labelLower.includes(w))) {
                var officeCity = off.city || key;
            html += `<div class="mw-item" onclick="slSelectOffice('${uid}','${label}','${off.code}','${off.postCode || ''}','${officeCity}')">🏢 ${label}</div>`;
                count++;
            }
            if (count >= 20) return false;
        });
