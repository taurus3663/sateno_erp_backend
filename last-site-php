		window.slRecalculate = function(targetId, postcode, cityName) {
    var $ = jQuery;
    if (!sl_ActiveUID) return;
    var uid = sl_ActiveUID;

    $('#price-' + uid).html('<small style="color:#666; font-style:italic;">Изчисляване...</small>');

    var payload = {
        site: window.location.hostname,
        cart_total: sl_CartTotal,
        cart_weight: parseFloat(sl_CartWeight),
        items_count: "<?php echo $cart->get_cart_contents_count(); ?>",
        currency: "<?php echo get_woocommerce_currency(); ?>",
        courierType: sl_CurrentCourier.toUpperCase() === 'BOXNOW' ? 'BOX_NOW' : sl_CurrentCourier.toUpperCase(),
        courierShipmentType: sl_CurrentMode.toUpperCase(),
        targetId: String(targetId),
        postcode: String(postcode),
        cityName: String(cityName),
        items: <?php echo json_encode($cart_items); ?>
    };

    $.ajax({
        url: 'https://erp.sateno.bg/erp/checkout/recalculate-price',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function(res) {
    // Тъй като отговорът е директно число (напр. 4.44)
    if (res !== undefined && res !== null && res !== "") {
        var p = parseFloat(res); // Превръщаме отговора в число

        if (!isNaN(p)) {
            var symbol = sl_CurrencySymbol;
            var html = (p <= 0)
                ? '<span class="sl-badge-free">БЕЗПЛАТНО</span>'
                : '<span class="sl-price-tag">' + p.toFixed(2) + ' ' + symbol + '</span>';

            // Намираме елемента и го обновяваме
            $('#price-' + uid).html(html);

            // Казваме на WooCommerce да обнови тоталите
            $(document.body).trigger('update_checkout');
        } else {
            console.error("Върнатият отговор не е валидно число:", res);
        }
    }
},
        error: function(err) {
            console.error("Грешка при връзка с ERP за цена.", err);
        }
    });
};

