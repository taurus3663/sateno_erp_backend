		function slCheckType(name, mode, courier) {
    if (courier === 'boxnow') return true;

    var n = name.toLowerCase();

    // Ако сме избрали режим АВТОМАТ
    if (mode === 'locker') {
        return n.includes('автомат') || n.includes('apm') || n.includes('locker') || n.includes('aps');
    }

    // Ако сме избрали режим ОФИС - тук е добре да СКРИЕМ автоматите, за да не се бъркат хората
    if (mode === 'office') {
        return !(n.includes('автомат') || n.includes('apm') || n.includes('locker') || n.includes('aps'));
    }

    return true;
}

       $(document).on('input focus', '.combined-search', function() {
