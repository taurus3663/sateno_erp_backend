function siliyan_erp_advanced_search() {

    // 1. ПОДГОТОВКА НА ДАННИТЕ ОТ КОЛИЧКАТА
    $cart = WC()->cart;
    $cart_items = array();
    $total_weight = 0;

    foreach ( $cart->get_cart() as $cart_item_key => $cart_item ) {
        $_product   = apply_filters( 'woocommerce_cart_item_product', $cart_item['data'], $cart_item, $cart_item_key );
        $quantity   = $cart_item['quantity'];
        $price      = $cart_item['line_total'];
        $weight     = (float)$_product->get_weight() * $quantity;

        $total_weight += $weight;

        $cart_items[] = array(
            'id'       => $cart_item['product_id'],
            'name'     => $_product->get_name(),
            'sku'      => $_product->get_sku(),
            'quantity' => $quantity,
            'price'    => $price,
            'weight'   => (float)$_product->get_weight(),
        );
    }

    $site_domain = $_SERVER['HTTP_HOST'];
    $api_url = 'http://77.71.76.17:9494/erp/checkout/check-couriers';

    $request_body = array(
        'site'         => $site_domain,
        'cart_total'   => $cart->get_total('edit'),
        'cart_weight'  => $total_weight,
        'items_count'  => $cart->get_cart_contents_count(),
        'items'        => $cart_items,
        'currency'     => get_woocommerce_currency()
    );

    $args = array(
        'body'        => json_encode( $request_body ),
        'headers'     => array( 'Content-Type' => 'application/json' ),
        'timeout'     => 15,
        'blocking'    => true,
    );

    // 2. ИЗПРАЩАНЕ КЪМ JAVA ЗА ПЪРВОНАЧАЛНИ ЦЕНИ
    $response = wp_remote_post( $api_url, $args );
    if ( is_wp_error( $response ) ) return;

    $data = json_decode( wp_remote_retrieve_body( $response ), true );
    $delivery_options = isset($data['checkOutCourierList']) ? $data['checkOutCourierList'] : [];
    $currency_symbol = isset($data['currencySymbol']) ? $data['currencySymbol'] : '€';

    // Сортировка
    if (!empty($delivery_options)) {
        usort($delivery_options, function($a, $b) {
            $orderA = isset($a['sortOrder']) ? (int)$a['sortOrder'] : 999;
            $orderB = isset($b['sortOrder']) ? (int)$b['sortOrder'] : 999;
            return $orderA <=> $orderB;
        });
    }

    $cities_res = wp_remote_get("https://couriers.lynk.bg/new/bg-cities.txt");
    $cities_json = !is_wp_error($cities_res) ? wp_remote_retrieve_body($cities_res) : '{}';

