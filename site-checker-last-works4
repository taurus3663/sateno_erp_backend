add_action('wp_ajax_nopriv_sl_recalculate_proxy', 'sl_recalculate_proxy_func');

function sl_recalculate_proxy_func() {
    $json_data = file_get_contents('php://input');
    $java_api_url = 'http://77.71.76.17:9494/erp/checkout/recalculate-price';

    $response = wp_remote_post($java_api_url, array(
        'body'    => $json_data,
        'headers' => array('Content-Type' => 'application/json'),
        'timeout' => 15
    ));

    if (is_wp_error($response)) {
        wp_send_json_error($response->get_error_message());
    } else {
        echo wp_remote_retrieve_body($response);
    }
    wp_die();
}