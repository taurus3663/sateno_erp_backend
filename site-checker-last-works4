    <script>
    function slTriggerRecalculate(targetId, postcode = '', cityName = '') {
        var $ = jQuery;


		// 1. Пълним стандартните Billing полета на WooCommerce веднага
    $('#billing_city').val(cityName);
    $('#billing_postcode').val(postcode);

    // 2. Определяме адреса: ако е офис, взимаме името му от инпута, ако е адрес - от улицата
    var uid = sl_CurrentCourier.toLowerCase() + '_' + sl_CurrentMode.toLowerCase();
    var finalAddr = "";

    if (sl_CurrentMode === 'office' || sl_CurrentMode === 'locker') {
        finalAddr = "Офис: " + $('#input-' + uid).val();
    } else {
        // Взимаме стойността от твоето поле за улица
        finalAddr = $('input[name="sl_street_' + uid + '"]').val() || "";
    }

    $('#billing_address_1').val(finalAddr);

    // 3. Казваме на WooCommerce, че има промяна (за да се обновят данните в сесията)
    $(document.body).trigger('update_checkout');


        if (!sl_CurrentCourier || !sl_CurrentMode) return;

        var uid = sl_CurrentCourier.toLowerCase() + '_' + sl_CurrentMode.toLowerCase();
        var $card = $('#box-' + uid);

        var isAuto = $card.data('autoShippingPrice');
        if (isAuto === false || isAuto === "false" || isAuto === 0) {
            $(document.body).trigger('update_checkout');
            return;
        }

        var $priceHolder = $card.find('.price-holder');
        $priceHolder.html(' <small style="color:orange;">Изчисляване...</small>');

        // СЪЗДАВАМЕ ПЪЛЕН ПАКЕТ ДАННИ ЗА JAVA DTO
        var payload = {
            site: window.location.hostname,
            cart_total: sl_CartTotal,
            cart_weight: parseFloat(sl_CartWeight),
            items_count: "<?php echo $cart->get_cart_contents_count(); ?>",
            currency: "<?php echo get_woocommerce_currency(); ?>",
            courierType: sl_CurrentCourier.toUpperCase() === 'BOXNOW' ? 'BOX_NOW' : sl_CurrentCourier.toUpperCase(),
            courierShipmentType: sl_CurrentMode.toUpperCase() === 'LOCKER' ? 'LOCKER' : (sl_CurrentMode.toUpperCase() === 'OFFICE' ? 'OFFICE' : 'ADDRESS'),
            targetId: String(targetId),
            postcode: String(postcode),
            cityName: String(cityName), // ВечеcityName винаги се праща
            items: <?php echo json_encode($cart_items); ?>
        };

//         console.log("--- SENDING RECALC TO PROXY ---", payload);

        $.ajax({
            url: '<?php echo admin_url('admin-ajax.php'); ?>?action=sl_recalculate_proxy',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(payload),
            success: function(newPrice) {
                var price = parseFloat(newPrice);
                var uid = sl_CurrentCourier.toLowerCase() + '_' + sl_CurrentMode.toLowerCase();
                var $pH = $('#box-' + uid).find('.price-holder');

                if (isNaN(price) || price <= 0) {
                    $pH.html(' <span class="sl-badge-free">БЕЗПЛАТНО</span>');
                } else {
                    var pBgn = (price * sl_ExchangeRate).toFixed(2);
                    var html = ' <span class="sl-price-tag">' + price.toFixed(2) + ' ' + sl_CurrencySymbol +
                               ' <small>(' + pBgn + ' лв.)</small></span>';
                    $pH.html(html);
                }
                $(document.body).trigger('update_checkout');
            },
            error: function() {
                var $pH = $('#box-' + sl_CurrentCourier.toLowerCase() + '_' + sl_CurrentMode.toLowerCase()).find('.price-holder');
                $pH.html(' <small style="color:red;">Грешка</small>');
            }
        });
    }

    function slOpen(courier, mode, courierId) {
        var $ = jQuery;
        var uid = courier + '_' + mode;
        sl_CurrentCourier = courier;
        sl_CurrentMode = mode;

        $('.sl-card').removeClass('active'); $('.sl-dropdowns').hide();
        $('#box-' + uid).addClass('active').find('.sl-dropdowns').show();
        $('#r-' + uid).prop('checked', true);

        $('#final-courier-id').val(courierId);
        $('#final-mode').val(mode);

        if ((mode === 'office' || mode === 'locker') && !sl_MasterDB[courier]) {
            $.getJSON("<?php echo admin_url('admin-ajax.php'); ?>", { action: 'sl_get_data_v6', type: courier }, function(res) {
                sl_MasterDB[courier] = res;
            });
        }
        $(document.body).trigger('update_checkout');
    }

    jQuery(document).on('click', '.office-trigger', function() {
        var $ = jQuery;
        var uid = $(this).data('uid');
        var cityName = $(this).data('city'); // Взимаме града от атрибута

        $('#input-' + uid).val($(this).data('text'));
        $('#val-' + uid).val($(this).data('id'));
        $('.mw-results-list').hide();

        // Подаваме cityName на калкулатора
        slTriggerRecalculate($(this).data('id'), '', cityName);
    });

		// Функция, която събира всичко и го праща към Billing
function slGlobalSync() {
    var $ = jQuery;
    if (!sl_CurrentCourier || !sl_CurrentMode) return;

    var uid = sl_CurrentCourier.toLowerCase() + '_' + sl_CurrentMode.toLowerCase();

    var courierTag = sl_CurrentCourier.toUpperCase(); // SPEEDY, ECONT, BOXNOW
    var modeTag = sl_CurrentMode.toUpperCase();       // OFFICE, LOCKER, ADDRESS

    var city = "";
    var pc = "";
    var finalAddr = "";
    var officeId = $('#val-' + uid).val() || "";

    if (sl_CurrentMode === 'office' || sl_CurrentMode === 'locker') {
        var officeName = $('#input-' + uid).val() || "";

        // ФОРМАТ: [OFFICE] Име на обект [1234] [ECONT]
        finalAddr = "[" + modeTag + "] " + officeName + " [" + officeId + "] [" + courierTag + "]";

        city = $('#city-sync-' + uid).val() || officeName.split(' - ')[0] || "";
        pc = $('#postcode-' + uid).val() || "";
    } else {
        // ДО АДРЕС
        var street = $('input[name="sl_street_' + uid + '"]').val() || "";

        // ФОРМАТ: [ADDRESS] ул. Име на улица 10 [] [ECONT]
        // Оставяме празни скоби за ID, за да е еднакъв броят на групите за Regex
        finalAddr = "[" + modeTag + "] " + street + " [] [" + courierTag + "]";

        city = $('#city-hidden-' + uid).val() || "";
        pc = $('#postcode-' + uid).val() || "";
    }

    // Пълним стандартните Billing полета
    $('#billing_city').val(city.trim());
    $('#billing_postcode').val(pc.trim());
    $('#billing_address_1').val(finalAddr.trim());

    // Пълним и Shipping (за да излиза и в двата обекта в GSON-а)
    $('#shipping_city').val(city.trim());
    $('#shipping_postcode').val(pc.trim());
    $('#shipping_address_1').val(finalAddr.trim());

//     console.log("--- SILIYAN ERP FINAL SYNC ---");
//     console.log("Address_1: " + finalAddr);
//     console.log("City: " + city);
//     console.log("Postcode: " + pc);
}
// СЛЕДИМ ВСИЧКИ ВЪЗМОЖНИ ПРОМЕНИ
// 1. Когато се пише в поле за търсене или улица
jQuery(document).on('input', '.sl-search-input, .combined-search, .city-autocomplete', function() {
    slGlobalSync();
});

// 2. Когато се избере нещо от списък (офис или град)
jQuery(document).on('click', '.mw-item', function() {
    // Малък delay, за да сме сигурни, че твоите скриптове първо са попълнили полетата
    setTimeout(slGlobalSync, 100);
});

// 3. Когато се сменя метода (картите)
jQuery(document).on('click', '.sl-card', function() {
    setTimeout(slGlobalSync, 100);
});

    jQuery(document).on('click', '.city-select', function() {
        var $ = jQuery;
        var uid = $(this).data('uid');
