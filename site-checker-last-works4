    jQuery(document).on('input focus', '.city-autocomplete', function() {
    var $ = jQuery;
    var uid = this.id.replace('city-input-', '');
    var term = $(this).val().trim().toLowerCase();
    var resDiv = $('#city-results-' + uid);

    if (!sl_CitiesList) return;

    var html = ''; var count = 0;
    $.each(sl_CitiesList, function(cityName, zipData) {
        $.each(zipData, function(postCode, detailsArray) {
            if (term === "" || cityName.toLowerCase().includes(term) || postCode.includes(term)) {
                html += `<div class="mw-item city-select"
                              data-uid="${uid}"
                              data-city="${cityName}"
                              data-postcode="${postCode}"
                              data-id="${cityName}">📍 ${cityName} <b>(${postCode})</b></div>`;
                count++;
            }
            if (count >= 15) return false;
        });
        if (count >= 15) return false;
    });
    resDiv.html(html).show();
});

    jQuery(document).on('input focus', '.combined-search', function() {
        var $ = jQuery; var uid = this.id.replace('input-', '');
        var courier = uid.split('_')[0]; var mode = uid.split('_')[1];
        var term = $(this).val().trim().toLowerCase();
        if (!sl_MasterDB[courier]) return;
        var words = term.split(/\s+/).filter(w => w.length > 0);
        var html = ''; var count = 0;
        $.each(sl_MasterDB[courier], function(key, value) {
            var offices = Array.isArray(value) ? value : [value];
            $.each(offices, function(i, off) {
                if (!off || !off.name) return;
                var city = (off.city ? off.city : (typeof key === 'string' ? key : '')).toUpperCase().trim();
                var label = (city ? city + " - " : "") + off.name;
                if (!slCheckType(label, mode, courier)) return;
                if (words.every(w => label.toLowerCase().includes(w))) {
                    // ДОБАВИХМЕ data-city="${city}" за офисите
                    html += `<div class="mw-item office-trigger"
                                  data-uid="${uid}"
                                  data-id="${off.code || off.id}"
                                  data-city="${city}"
                                  data-text="${label}">🏢 ${label}</div>`;
                    count++;
                }
                if (count >= 30) return false;
            });
            if (count >= 30) return false;
        });
        $('#results-' + uid).html(html || '<div class="mw-item">Няма резултати</div>').show();
    });

    function slCheckType(name, mode, courier) {
        if (courier === 'boxnow') return true;
        if (mode !== 'locker') return true;
        var n = name.toLowerCase();
        return n.includes('автомат') || n.includes('apm') || n.includes('locker');
    }

    function slQuick(uid, city) { jQuery('#input-' + uid).val(city).trigger('input').focus(); }
