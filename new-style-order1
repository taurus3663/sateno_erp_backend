// 2. СКРИВАНЕ НА СТАНДАРТНИТЕ ПОЛЕТА
add_filter( 'woocommerce_checkout_fields', function( $fields ) {
    $allowed = ['billing_first_name', 'billing_last_name', 'billing_phone', 'billing_email'];
    foreach ( $fields['billing'] as $key => $field ) {
        if ( ! in_array( $key, $allowed ) ) {
            $fields['billing'][$key]['type'] = 'hidden';
            $fields['billing'][$key]['label'] = '';
            $fields['billing'][$key]['required'] = false;
        }
    }
    return $fields;
});

// 3. ДОБАВЯНЕ НА СКРИТИ ПОЛЕТА ЗА ERP-ТО
add_filter( 'woocommerce_billing_fields' , 'siliyan_add_custom_billing_fields' );
function siliyan_add_custom_billing_fields( $fields ) {
    $fields['billing_office_code'] = array('type' => 'hidden', 'required' => false, 'class' => array('sl-hidden'));
    $fields['billing_courier_type'] = array('type' => 'hidden', 'required' => false, 'class' => array('sl-hidden'));
    return $fields;
}

