function sl_recalculate_proxy_func() {
    $response = wp_remote_post('http://77.71.76.17:9494/erp/checkout/recalculate-price', array(
        'body' => file_get_contents('php://input'),
        'headers' => array('Content-Type' => 'application/json'),
        'timeout' => 15
    ));
    echo is_wp_error($response) ? '0' : wp_remote_retrieve_body($response);
    wp_die();
}

add_action( 'woocommerce_checkout_order_processed', function( $order_id, $posted_data, $order ) {
    $api_url = 'http://77.71.76.17:9494/erp/wp_order/create';
    $secret  = 'a319b7ce-f428-46e7-90be-e753fe83efa7';

    $data = $order->get_data();
    foreach (['date_created', 'date_modified', 'date_completed', 'date_paid'] as $f) {
        if (isset($data[$f]) && $data[$f] instanceof WC_DateTime) $data[$f] = $data[$f]->date_i18n('Y-m-d\TH:i:s');
    }

    $data['line_items'] = array();
    foreach ($order->get_items() as $item) $data['line_items'][] = $item->get_data();

    $payload   = json_encode( $data );
    $signature = base64_encode( hash_hmac( 'sha256', $payload, $secret, true ) );

    $args = array(
        'body'        => $payload,
        'headers'     => array(
            'Content-Type'           => 'application/json',
            'x-wc-webhook-signature' => $signature,
            'x-wc-webhook-topic'     => 'order.created',
            'x-wc-webhook-resource'  => 'order',
            'x-wc-webhook-event'     => 'created',
            'User-Agent'             => 'WooCommerce/Siliyan-ERP-Push'
        ),
        'timeout'     => 60,
        'blocking'    => false,
        'sslverify'   => false,
    );

    wp_remote_post( $api_url, $args );
}, 10, 3 );