add_action( 'woocommerce_after_checkout_billing_form', 'siliyan_erp_advanced_search' );

function siliyan_erp_advanced_search() {
    $cart = WC()->cart;
    $cart_items = array();
    $total_weight = 0;

    foreach ( $cart->get_cart() as $cart_item_key => $cart_item ) {
        $_product = $cart_item['data'];
        $quantity = $cart_item['quantity'];
        $total_weight += (float)$_product->get_weight() * $quantity;
        $cart_items[] = array(
            'id'       => $cart_item['product_id'],
            'name'     => $_product->get_name(),
            'sku'      => $_product->get_sku(),
            'quantity' => $quantity,
            'price'    => $cart_item['line_total'],
            'weight'   => (float)$_product->get_weight(),
        );
    }

    $api_url = 'http://77.71.76.17:9494/erp/checkout/check-couriers';
    $response = wp_remote_post( $api_url, array(
        'body'    => json_encode(array(
            'site'        => $_SERVER['HTTP_HOST'],
            'cart_total'  => $cart->get_total('edit'),
            'cart_weight' => $total_weight,
            'items_count' => $cart->get_cart_contents_count(),
            'items'       => $cart_items,
            'currency'    => get_woocommerce_currency()
        )),
        'headers' => array( 'Content-Type' => 'application/json' ),
        'timeout' => 15
    ));

    if ( is_wp_error( $response ) ) return;

    $data = json_decode( wp_remote_retrieve_body( $response ), true );
    $delivery_options = $data['checkOutCourierList'] ?? [];
    $currency_symbol = $data['currencySymbol'] ?? '€';
    $cities_json = wp_remote_retrieve_body(wp_remote_get("https://couriers.lynk.bg/new/bg-cities.txt"));

    if (!empty($delivery_options)) {
        usort($delivery_options, function($a, $b) {
            $orderA = (isset($a['sortOrder']) && $a['sortOrder'] !== null) ? (int)$a['sortOrder'] : 999;
            $orderB = (isset($b['sortOrder']) && $b['sortOrder'] !== null) ? (int)$b['sortOrder'] : 999;
            return $orderA <=> $orderB;
        });
    }
    ?>

    <script>
        var sl_CitiesList = <?php echo $cities_json ?: '{}'; ?>;
        var sl_MasterDB = { speedy: null, econt: null, boxnow: null };
        var sl_CurrentCourier = '';
        var sl_CurrentMode = '';
        var sl_ActiveUID = '';
    </script>

    <div id="sl-shipping-system" style="clear:both; margin-top:30px;">
        <h3 style="font-weight:600; margin-bottom:15px; font-size:18px;">Метод на доставка</h3>

        <div class="sl-shipping-wrapper" style="display: flex; flex-direction: column; gap: 10px;">
        <?php
        if (!empty($delivery_options)) :
            foreach ($delivery_options as $opt):
                $slug = str_replace('_', '', strtolower($opt['courierType']));
                $courier_id = $opt['id'] ?? 0;

                // КОНФИГУРАЦИЯ БЕЗ ОБЩА ЦЕНА - ВСЕКИ МЕТОД ГЛЕДА СОБСТВЕНАТА СИ КОЛОНА
                $modes_config = [
                    'office'  => [
                        'label' => 'До офис',
                        'price' => (float)($opt['officeFixedShippingPrice'] ?? 0)
                    ],
                    'locker'  => [
                        'label' => 'До автомат',
                        'price' => (float)($opt['lockerFixedShippingPrice'] ?? 0)
