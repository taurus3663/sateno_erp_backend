            $('#final-courier-id').val(courierId); $('#final-mode').val(mode);
            if ((mode === 'office' || mode === 'locker') && !sl_MasterDB[courier]) {
                var u = { 'speedy': 'https://couriers.lynk.bg/new/bg-speedy-offices.txt', 'econt': 'https://couriers.lynk.bg/new/bg-econt-offices.txt', 'boxnow': 'https://couriers.lynk.bg/new/bg-boxnow-offices.txt' };
                $.get(u[courier], function(res) { sl_MasterDB[courier] = (typeof res === 'string') ? JSON.parse(res) : res; });
            }
            $(document.body).trigger('update_checkout');
        };

        window.slGlobalSync = function() {
            if (!sl_ActiveUID) return;
            var uid = sl_ActiveUID, city = "", pc = "", addr = "";
            if (sl_CurrentMode !== 'address') {
                var name = $('#input-' + uid).val() || "", code = $('#val-' + uid).val() || "";
                addr = "[" + sl_CurrentMode.toUpperCase() + "] " + name + " [" + code + "] [" + sl_CurrentCourier.toUpperCase() + "]";
                city = name.split(' - ')[0] || "";
            } else {
                var street = $('#street-' + uid).val() || "";
                city = $('#city-hidden-' + uid).val() || ""; pc = $('#postcode-' + uid).val() || "";
                addr = "[ADDRESS] " + street + " [] [" + sl_CurrentCourier.toUpperCase() + "]";
            }
            $('#billing_city, #shipping_city').val(city.trim());
            $('#billing_postcode, #shipping_postcode').val(pc.trim());
            $('#billing_address_1, #shipping_address_1').val(addr.trim());
        };

        $(document).on('input focus', '.combined-search', function() {
            var uid = this.id.replace('input-', ''), courier = uid.split('_')[0];
            var term = $(this).val().toLowerCase();
            if (!sl_MasterDB[courier]) return;
            var html = '', count = 0, words = term.split(/\s+/);
            $.each(sl_MasterDB[courier], function(key, value) {
                $.each(Array.isArray(value) ? value : [value], function(i, off) {
                    var label = (off.city || key).toUpperCase() + " - " + off.name;
                    if (words.every(w => label.toLowerCase().includes(w))) {
                        html += `<div class="mw-item" onclick="slSelectOffice('${uid}','${label}','${off.code}')">🏢 ${label}</div>`;
                        count++;
                    }
                    if (count >= 20) return false;
                });
                if (count >= 20) return false;
            });
            $('#results-' + uid).html(html).show();
        });

        $(document).on('input focus', '.city-autocomplete', function() {
            var uid = this.id.replace('city-input-', ''), term = $(this).val().toLowerCase(), html = '', count = 0;
            $.each(sl_CitiesList, function(city, zips) {
                if (city.toLowerCase().includes(term)) {
                    $.each(zips, function(pc, data) {
                        html += `<div class="mw-item" onclick="slSelectCity('${uid}','${city}','${pc}')">📍 ${city} (${pc})</div>`;
                        count++;
                    });
                }
                if (count >= 10) return false;
            });
            $('#city-results-' + uid).html(html).show();
        });

        window.slSelectOffice = function(uid, label, code) {
            $('#input-' + uid).val(label); $('#val-' + uid).val(code); $('.mw-results-list').hide(); slGlobalSync();
        };

        window.slSelectCity = function(uid, city, pc) {
            $('#city-input-' + uid).val(city + ' (' + pc + ')'); $('#city-hidden-' + uid).val(city); $('#postcode-' + uid).val(pc); $('.mw-results-list').hide(); slGlobalSync();
        };

        $(document).on('input', '.sl-search-input', function() { slGlobalSync(); });
        window.slQuick = function(uid, city) { $('#input-' + uid).val(city).trigger('input').focus(); };
        $(document).on('click', function(e) { if (!$(e.target).closest('.sl-card').length) $('.mw-results-list').hide(); });
    })(jQuery);
    </script>
    <?php
}

