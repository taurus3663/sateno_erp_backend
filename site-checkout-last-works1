add_action( 'woocommerce_checkout_billing', 'siliyan_erp_advanced_search' );

function siliyan_erp_advanced_search() {

	$site_domain = $_SERVER['HTTP_HOST'];
    $api_url = 'http://77.71.76.17:9494/erp/checkout/check-couriers';

    $args = array(
        'body'        => json_encode( array( 'site' => $site_domain ) ),
        'headers'     => array(
            'Content-Type' => 'application/json',
            'Accept'       => 'application/json'
        ),
        'timeout'     => 15,
        'blocking'    => true, // Задължително за да чака отговор
    );

    $response = wp_remote_post( $api_url, $args );
	// Проверяваме дали няма грешка в самата заявка първо
if ( is_wp_error( $response ) ) {
    $error_msg = $response->get_error_message();
    echo "<script>console.error('PHP Debug Error: " . esc_js($error_msg) . "');</script>";
} else {
    // Вземаме тялото на отговора (това, което Java-та праща)
    $body = wp_remote_retrieve_body( $response );

    // Печатаме в конзолата като истински обект, за да можеш да го разцъкаш
    echo "<script>
        console.log('--- Java API Full Response ---');
        console.log(" . ($body ? $body : "'Empty Body'") . ");
    </script>";
}

