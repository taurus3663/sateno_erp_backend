    <script>
    var sl_MasterDB = { speedy: null, econt: null, boxnow: null };
    var sl_CitiesList = null;

    function slOpen(courier, mode) {
        var $ = jQuery;
        var unique_id = courier + '_' + mode;
        $('.sl-card').removeClass('active'); $('.sl-dropdowns').hide();
        $('#r-' + unique_id).prop('checked', true);
        $('#box-' + unique_id).addClass('active').find('.sl-dropdowns').show();
        $('#final-courier').val(courier);
        $('#final-mode').val(mode);

        if ((mode === 'office' || mode === 'locker') && !sl_MasterDB[courier]) {
            $.getJSON("<?php echo admin_url('admin-ajax.php'); ?>", { action: 'sl_get_data_v6', type: courier }, function(res) {
                sl_MasterDB[courier] = res;
            });
        }
        if (mode === 'address' && !sl_CitiesList) {
            $.getJSON("https://couriers.lynk.bg/new/bg-cities.txt", function(res) {
                sl_CitiesList = res;
            });
        }
        $(document.body).trigger('update_checkout');
    }

    // --- ФИЛТЪР ЗА ТИП ОБЕКТ ---
    function slCheckType(name, mode) {
        if (mode !== 'locker') return true;
        var n = name.toLowerCase();
        return n.includes('автомат') || n.includes('apm') || n.includes('locker');
    }

    // --- ЛОГИКА ЗА ГРАДОВЕ ---
    jQuery(document).on('input focus', '.city-autocomplete', function() {
        var $ = jQuery;
        var uid = this.id.replace('city-input-', '');
        var term = $(this).val().trim().toLowerCase();
        var resDiv = $('#city-results-' + uid);
        if (!sl_CitiesList) return;
        var html = ''; var count = 0;
        $.each(sl_CitiesList, function(cityName, zipData) {
            $.each(zipData, function(postCode, detailsArray) {
                if (!Array.isArray(detailsArray) || detailsArray.length === 0) return;
                var details = detailsArray[0];
                var nameEn = details.nameEn || "";
                if (term === "" || cityName.toLowerCase().includes(term) || nameEn.toLowerCase().includes(term) || postCode.includes(term)) {
                    html += `<div class="mw-item city-select" data-uid="${uid}" data-city="${cityName}" data-postcode="${postCode}">📍 ${cityName} <b>(${postCode})</b></div>`;
                    count++;
                }
                if (count >= 20) return false;
            });
            if (count >= 20) return false;
        });
        resDiv.html(html || '<div class="mw-item">Няма намерен резултат...</div>').show();
    });

    jQuery(document).on('click', '.city-select', function() {
        var $ = jQuery;
        var uid = $(this).data('uid');
        var city = $(this).data('city');
        var pc = $(this).data('postcode');
        $('#city-input-' + uid).val(city + ' (' + pc + ')');
        $('#city-hidden-' + uid).val(city);
        $('#postcode-' + uid).val(pc);
        $('#city-results-' + uid).hide();
        $(document.body).trigger('update_checkout');
    });

    // --- ЛОГИКА ЗА ОФИСИ / АВТОМАТИ ---
    jQuery(document).on('input focus', '.combined-search', function() {
        var $ = jQuery;
        var uid = this.id.replace('input-', '');
        var courier = uid.split('_')[0];
        var mode = uid.split('_')[1];
        var term = $(this).val().trim().toLowerCase();
        var resDiv = $('#results-' + uid);
        if (!sl_MasterDB[courier]) return;
        if (term.length === 0) { renderInitial(uid, courier, mode); return; }
        var words = term.split(/\s+/).filter(w => w.length > 0);
        var html = ''; var count = 0;
        for (var key in sl_MasterDB[courier]) {
            var offices = sl_MasterDB[courier][key];
            for (var i = 0; i < offices.length; i++) {
                var off = offices[i];
                var cityName = (off.city ? off.city : key.toUpperCase()).trim();
                var label = off.name.toLowerCase().includes(cityName.toLowerCase()) ? off.name : cityName + " - " + off.name;

                if (!slCheckType(label, mode)) continue;

                if (words.every(word => label.toLowerCase().includes(word))) {
                    html += `<div class="mw-item office-trigger" data-uid="${uid}" data-id="${off.code}" data-text="${label}">🏢 ${label}</div>`;
                    count++;
                }
                if (count >= 50) break;
            }
            if (count >= 50) break;
        }
        resDiv.html(html || '<div class="mw-item">Няма резултати</div>').show();
    });

    function renderInitial(uid, courier, mode) {
        var $ = jQuery; var html = ''; var count = 0;
        for (var key in sl_MasterDB[courier]) {
            var offices = sl_MasterDB[courier][key];
            for (var i = 0; i < offices.length; i++) {
                var off = offices[i];
                var cityName = (off.city ? off.city : key.toUpperCase()).trim();
                var combined = cityName + " - " + off.name;

                if (!slCheckType(combined, mode)) continue;

                html += `<div class="mw-item office-trigger" data-uid="${uid}" data-id="${off.code}" data-text="${combined}">🏢 ${combined}</div>`;
                count++; if (count >= 50) break;
            }
            if (count >= 50) break;
        }
        $('#results-' + uid).html(html).show();
    }

    jQuery(document).on('click', '.office-trigger', function() {
        var $ = jQuery; var uid = $(this).data('uid');
        $('#input-' + uid).val($(this).data('text'));
        $('#val-' + uid).val($(this).data('id'));
        $('#results-' + uid).hide();
        $(document.body).trigger('update_checkout');
    });

    jQuery(document).on('click', function(e) {
        if (!jQuery(e.target).closest('.sl-card').length) { jQuery('.mw-results-list').hide(); }
    });

    function slQuick(uid, city) { jQuery('#input-' + uid).val(city).trigger('input').focus(); }
    </script>
    <?php
}

add_action('wp_ajax_sl_get_data_v6', function() {
    $u = ['speedy' => 'https://couriers.lynk.bg/new/bg-speedy-offices.txt', 'econt' => 'https://couriers.lynk.bg/new/bg-econt-offices.txt', 'boxnow' => 'https://couriers.lynk.bg/new/bg-boxnow-offices.txt'];
    echo wp_remote_retrieve_body(wp_remote_get($u[$_GET['type']], ['timeout' => 30]));
    wp_die();
});

add_action( 'woocommerce_checkout_update_order_meta', function($order_id) {
    $courier = $_POST['siliyan_courier'] ?? '';
    $mode = $_POST['siliyan_mode'] ?? '';
    $uid = $courier . '_' . $mode;
    update_post_meta($order_id, '_siliyan_courier', $courier);
    update_post_meta($order_id, '_siliyan_mode', $mode);
    if ($mode === 'office' || $mode === 'locker') {
        update_post_meta($order_id, '_siliyan_office_id', $_POST['sl_val_' . $uid] ?? '');
    } else {
        update_post_meta($order_id, '_siliyan_city', $_POST['sl_city_' . $uid] ?? '');
        update_post_meta($order_id, '_siliyan_postcode', $_POST['sl_postcode_' . $uid] ?? '');
        update_post_meta($order_id, '_siliyan_street', $_POST['sl_street_' . $uid] ?? '');
    }
});